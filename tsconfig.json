{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/effect": ["./packages/providers/src/effect/index.ts"],
      "@/*": ["./packages/opencode-app/src/*", "./packages/shared/src/util-mocks/*"],
      "@opencode-ai/core/*": ["./packages/shared/src/core-mocks/*"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "packages/**/*.ts"
  ]
}
